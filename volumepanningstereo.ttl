@prefix doap:   <http://usefulinc.com/ns/doap#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix pg:     <http://lv2plug.in/ns/ext/port-groups#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units:  <http://lv2plug.in/ns/extensions/units#> .

<http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoIn>
    a pg:StereoGroup, pg:InputGroup ;
    lv2:symbol "stereo_in" ;
    rdfs:label "Stereo Input" .

<http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoOut>
    a pg:StereoGroup, pg:OutputGroup ;
    lv2:symbol "stereo_out" ;
    rdfs:label "Stereo Output" .

<http://fprice.pricemail.ca/plugins/volumepanningstereo>
    a lv2:Plugin, lv2:AmplifierPlugin ;

    doap:name "Volume Panning Stereo" ;
    doap:shortdesc "Stereo volume, pan, mute, and bypass" ;
    doap:license <https://opensource.org/licenses/BSD-3-Clause> ;
    doap:maintainer [
        foaf:name "Frederick Price" ;
        foaf:mbox <mailto:fprice@pricemail.ca>
    ] ;

    lv2:optionalFeature lv2:hardRTCapable ;

    lv2:port [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "in_l" ;
        lv2:name "Input L" ;
        pg:group <http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoIn> ;
        lv2:designation pg:left ;
    ] , [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "in_r" ;
        lv2:name "Input R" ;
        pg:group <http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoIn> ;
        lv2:designation pg:right ;
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 2 ;
        lv2:symbol "out_l" ;
        lv2:name "Output L" ;
        pg:group <http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoOut> ;
        lv2:designation pg:left ;
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 3 ;
        lv2:symbol "out_r" ;
        lv2:name "Output R" ;
        pg:group <http://fprice.pricemail.ca/plugins/volumepanningstereo#stereoOut> ;
        lv2:designation pg:right ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "enabled" ;
        lv2:name "Enabled" ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled, lv2:integer ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "volume" ;
        lv2:name "Volume" ;
        lv2:default 0.0 ;
        lv2:minimum -60.0 ;
        lv2:maximum 20.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "pan" ;
        lv2:name "Pan" ;
        lv2:default 0.0 ;
        lv2:minimum -1.0 ;
        lv2:maximum 1.0 ;
        units:unit units:coef ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "mute" ;
        lv2:name "Mute" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled, lv2:integer ;
    ] , [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "mute_invert" ;
        lv2:name "Mute Invert" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled, lv2:integer ;
    ] .
